        { "seq": 6, "speakerId": "S06", "speakerName": "人事", "speakerRole": "hr", "startedAtSec": 305, "durationSec": 21, "agendaStepId": "A2", "stance": "question", "content": "未発言者の意見確認を行ってから最終化したいです。" }
      ]
    },
    {
