        { "seq": 2, "speakerId": "S04", "speakerName": "評価者A", "speakerRole": "reviewer", "startedAtSec": 48, "durationSec": 39, "agendaStepId": "B1", "stance": "agree", "content": "賛成です。部門横断の調整能力は高いです。" },
